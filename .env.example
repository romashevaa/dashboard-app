# Supabase — client-safe values (exposed to the browser).
# Find these in the Supabase dashboard → Project Settings → API,
# or run `pnpm supabase start` and use the printed local values.
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Corporate email-domain allow-list (comma-separated). Mirrors the
# authoritative DB auth hook. Confirm the exact domain before going live.
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAINS="webfolks.io"

# Server-only secrets — NEVER expose to the client or commit real values.
# Used by privileged server tasks (e.g. future Sheets sync / admin jobs).
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
