# Supabase — client-safe values (exposed to the browser).
# Find these in the Supabase dashboard → Project Settings → API,
# or run `pnpm supabase start` and use the printed local values.
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Corporate email-domain allow-list (comma-separated). Mirrors the
# authoritative DB auth hook. Confirm the exact domain before going live.
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAINS="webfolks.io"

# Server-only secrets — NEVER expose to the client or commit real values.
# Used by privileged server tasks: removing a user from the admin panel
# (deletes the auth user), and future Sheets sync / admin jobs. Find it in
# Supabase → Project Settings → API → service_role key (or `pnpm supabase start`).
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Slack bot token (xoxb-…) for the "Import from Slack" button on the profile
# page. Scopes: users:read, users:read.email, users.profile:read. Optional —
# the button only shows when this is set. Server-only; never expose it.
# SLACK_BOT_TOKEN="xoxb-your-bot-token"
